<% layout("/layout/boilerplate") %>
<body>
    <div class="col">
        <div class="col-8 offset-2">
            <h3>Create a new listing</h3>
            <br>
            <form method="POST" action="/listing" class="needs-validation" novalidate>
                <div>
                    <label for="title" class="form-label">Title</label>
                    <input name="title" class="form-control" type="text" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        not good!
                      </div>
                </div>
                <br>
                <div>
                    <label for="description" class="form-label">Description</label>
                    <textarea name="description" class="form-control" type="text" required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        not good!
                      </div>
                </div>
                <br>
                <div>
                    <label for="image" class="form-label">Image Link</label>
                    <input name="image" class="form-control" type="text">
                </div>
                <br>
                <div>
                    <label for="image" class="form-label">Upload Image</label>
                    <input name="listing[image]" class="form-control" type="file">
                </div>
                <br>
                <div class="row">
                    <div class="col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <input name="price" class="form-control" type="number" required>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                        <div class="invalid-feedback">
                            enter valid price
                        </div>
                    </div>
                    <br>
                    <div class="col-md-8">
                        <label for="latitude" class="form-label">Latitude</label>
                        <input name="latitude" class="form-control" type="number" step="0.0000000001" >
                    </div>
                    <div class="col-md-8">
                        <label for="longitude" class="form-label">Longitude</label>
                        <input name="longitude" class="form-control" type="number" step="0.0000000001" >
                    </div>
                </div>
                <br>
                <div>
                    <label for="location" class="form-label">Location</label>
                    <input name="location" class="form-control" type="text" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                    <div class="invalid-feedback">
                        enter valid country
                      </div>
                </div>
                <br>
                <button class="btn btn-dark add-btn">Submit</button>
                <br><br><br><br><br><br><br><br>
            </form>
        </div>
    </div>
</body>
