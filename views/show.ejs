<% layout("/layout/boilerplate") %>
<body>
    <div class="col">
        <div class="card col-6 offset-3 listing-card">
            <br>
            <h3><%=listing.title%></h3><br>
            <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing">
            <br>
            <div class="card-body">
                <p class="card-text">Owned by: <i><%=listing.owner.username%></i> </p>
                <p class="card-text"> <%=listing.description%></p>
                <p class="card-text"> &#8377;<%=listing.price%> /night</p>
                <p class="card-text"> <%=listing.location%></p>
                <p class="card-text"> <%=listing.country%></p>
            </div>
        </div>
    </div>
    <% if(currUser && currUser._id.equals(listing.owner._id)){ %>
        <div class="btns  col">
            <div class="col-1 offset-3">
                <a class="btn btn-dark edit-btn" href="/listing/<%=listing._id%>/edit">Edit</a>
            </div>
            <br><br>
            <div class="col-1 offset-0.5 ">
                <form method="POST" action="/listing/<%=listing._id%>?_method=DELETE">
                    <button class="btn btn-dark">delete</button>
                </form> 
            </div>
        </div>
    <% } %>
    <div class="col-8 offset-3 mb-3">
        <hr>
        <% if(currUser) {%>
            <h4>Leave a review</h4>
            <form method="POST" action="/listing/<%=listing.id%>/review" class="needs-validation" novalidate>
                <!-- <div class="mb-3 mt-3">
                    <label class="form-label" for="rating">Rating</label>
                    <input name="review[rating]" id="rating" class="form-range" type="range" min="1" max="5">
                </div> -->
                <div class="mb-3 mt-3">
                    <label class="form-label" for="rating">Rating</label>
                    <fieldset class="starability-slot">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                <div class="mb-3 mt-3"> 
                    <label class="form-label" for="comment">Comment</label>
                    <textarea name="review[description]"  class="form-control" id="description" cols="30" rows="5" required></textarea>
                    <div class="valid-feedback">
                        Looks good
                    </div>
                    <div class="invalid-feedback">
                        Doesn't look good
                    </div>
                </div>
                <br>
                <button class="btn btn-outline-dark">Submit</button>
            </form>
        <hr>
        <% }%>
        <h4>All reviews:</h4>
        <div class="row">
            <%for(review of listing.reviews){%>
                <div class="card col-5 ms-3 mb-3 ">
                    <h5 class="card-title">@<%=review.author.username%></h5>
                    <p class="starability-result card-text" data-rating="<%=review.rating%>"></p>
                    <p class="card-text"><%=review.description%></p>
                    <% if(currUser && currUser._id.equals(review.author._id)){ %>
                        <form class="mb-3" method="POST" action="/listing/<%= listing._id%>/reviews/<%= review._id%>?_method=DELETE">
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form>
                    <% } %>
                </div>
            <%}%>
        </div>
        <hr>
        <h4>Listing Location:</h4>
        <div id="map" class="row card "></div>
    </div>
    <br><br><br><br><br><br><br><br><br><br><br><br><br><br>
</body>
<script>
    var map = L.map('map').setView(["<%=listing.lat%>","<%=listing.long%>"], 13);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
}).addTo(map);

navigator.geolocation.watchPosition(success,error);
let marker,circle,zoomed;
function success(pos){
    const lat= pos.coords.latitude;
    const long= pos.coords.laongitude;
    const accuracy = pos.coords.accuracy;
    if(marker){
        map.removeLayer(marker);
        map.removeLayer(circle);
    } 
    marker = L.marker(["<%=listing.lat%>","<%=listing.long%>"]).addTo(map);
    circle = L.circle(["<%=listing.lat%>","<%=listing.long%>"], {
    color: 'red',
    fillColor: '#f03',
    fillOpacity: 0.5,
    radius: 100
}).addTo(map);
    if(!zoomed){
        zoomed = map.fitBounds(circle.getBounds());
    };
    map.setView([lat,long]);
};
var popup = L.popup();

function onMapClick(e) {
    popup
        .setLatLng(e.latlng)
        .setContent("You clicked the map at " + e.latlng.toString())
        .openOn(map);
    }
map.on('click', onMapClick);
function error(err){
    if(err.code === 1){
        alert("Please allow geolocation access");
    }
    else{
        alert("Cannot get current location");
    }
};
</script>
